# Azure Speech Service
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=japaneast

# TTS Settings
TTS_VOICE=ja-JP-KeitaNeural
TTS_MAX_SPEED_RATIO=1.3

# Vietnamese TTS (LucyLab API)
VIETNAMESE_API_KEY=sk_live_your_key_here
VIETNAMESE_VOICEID_MALE=your_male_voice_id_here
VIETNAMESE_VOICEID_FEMALE=your_female_voice_id_here
VOICE_NARRATOR=your_neutral_voice_id_here
# Character voice mapping: CHAR_NAME:voice_id,CHAR_NAME2:voice_id2
VOICE_CHARACTER_MAP=NV_CHINH:your_voice_id_1,NV_PHU:your_voice_id_2
LUCYLAB_API_URL=https://api.lucylab.io/json-rpc
VIETNAMESE_TTS_MAX_SPEED=1.3
# Audio speed adjustment (0.82 = 18% slower, 1.0 = no change)
AUDIO_SLOW_FACTOR=0.82

# Video Input
VIDEO_URL=https://youtube.com/watch?v=xxx

# General
DEFAULT_SOURCE_LANG=en-US
AUDIO_SAMPLE_RATE=16000
OUTPUT_DIR=./output

# ==========================================
# AI Provider Refactoring Configurations
# ==========================================

# Active providers for each layer:
# - ASR_PROVIDER: 'groq' (default) or 'azure'
# - TRANSLATION_PROVIDER: 'deepseek' (default), 'openai', 'gemini', 'groq'
# - QA_REPAIR_PROVIDER: 'openai' (default), 'deepseek', 'gemini', 'groq'
ASR_PROVIDER=groq
TRANSLATION_PROVIDER=deepseek
QA_REPAIR_PROVIDER=openai

# Optional fallback chains (comma-separated providers list)
TRANSLATION_FALLBACK_PROVIDERS=openai,groq
QA_REPAIR_FALLBACK_PROVIDERS=deepseek,groq

# Set to true to re-enable Gemini (disabled by default to prevent 429 quota issues)
GEMINI_ENABLED=false

# Google Gemini API key (only used if GEMINI_ENABLED=true or as fallback/publishing)
GOOGLE_API_KEY=your_gemini_api_key_here

# Groq ASR & LLM config
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_ASR_MODEL=whisper-large-v3
GROQ_ASR_LANGUAGE_AUTO=false

# DeepSeek Translation config
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=60000
DEEPSEEK_MAX_RETRIES=5
DEEPSEEK_MIN_DELAY_MS=1500

# OpenAI QA / Repair config
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REPAIR_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=5

# Translation Pipeline Controls
TRANSLATION_WINDOW_SIZE=35
TRANSLATION_CONTEXT_BEFORE=3
TRANSLATION_CONTEXT_AFTER=3
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_PARTIAL_SAVE_ENABLED=true
TRANSLATION_FAIL_ON_CJK=true
TRANSLATION_FAIL_ON_UNTRANSLATED_TEXT=true
TRANSLATION_MAX_REPAIR_ROUNDS=2

# Subtitle-only mode configurations
SUBTITLE_ONLY_TIMING_OVERFLOW_IS_WARNING=true
VALIDATOR_HALLUCINATION_ENABLED=true
VALIDATOR_HALLUCINATION_SOURCE_CHAR_RATIO=2.5
VALIDATOR_ZH_VI_LENGTH_RATIO_AS_ERROR=false
VALIDATOR_ZH_VI_LENGTH_RATIO_WARNING_THRESHOLD=5.0
VALIDATOR_ZH_VI_LENGTH_RATIO_ERROR_THRESHOLD=8.0
VALIDATOR_SUBTITLE_MAX_CHARS_PER_SECOND=22
VALIDATOR_SUBTITLE_HARD_MAX_CHARS_PER_SECOND=32
