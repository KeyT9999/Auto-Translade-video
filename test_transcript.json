[
  {
    "id": 1,
    "text": "我们脆皮乳哥快点上呗",
    "start": 0,
    "end": 1.36,
    "duration": 1.36
  },
  {
    "id": 2,
    "text": "好的先生我去给您催一下",
    "start": 1.36,
    "end": 2.88,
    "duration": 1.52
  },
  {
    "id": 3,
    "text": "马上好了先生",
    "start": 5.28,
    "end": 6.16,
    "duration": 0.88
  },
  {
    "id": 4,
    "text": "又留了一圈",
    "start": 6.16,
    "end": 7.04,
    "duration": 0.88
  },
  {
    "id": 5,
    "text": "不然呢我催后厨",
    "start": 7.04,
    "end": 8.12,
    "duration": 1.08
  },
  {
    "id": 6,
    "text": "不得骂死我呀",
    "start": 8.12,
    "end": 8.84,
    "duration": 0.72
  },
  {
    "id": 7,
    "text": "试试呢",
    "start": 8.84,
    "end": 9.4,
    "duration": 0.56
  },
  {
    "id": 8,
    "text": "后厨后厨",
    "start": 10,
    "end": 10.6,
    "duration": 0.6
  },
  {
    "id": 9,
    "text": "小满包房的脆皮乳哥加急呗",
    "start": 10.6,
    "end": 12.16,
    "duration": 1.56
  },
  {
    "id": 10,
    "text": "催催催催啥催啊",
    "start": 12.16,
    "end": 13.44,
    "duration": 1.28
  },
  {
    "id": 11,
    "text": "我肯定是",
    "start": 13.44,
    "end": 14,
    "duration": 0.56
  },
  {
    "id": 12,
    "text": "太骂了",
    "start": 14,
    "end": 15.56,
    "duration": 1.56
  },
  {
    "id": 13,
    "text": "得劲",
    "start": 15.56,
    "end": 16.08,
    "duration": 0.52
  },
  {
    "id": 14,
    "text": "小满的主厨土豆丝",
    "start": 16.08,
    "end": 17.2,
    "duration": 1.12
  },
  {
    "id": 15,
    "text": "脆皮乳哥还没好啊",
    "start": 17.2,
    "end": 18.24,
    "duration": 1.04
  },
  {
    "id": 16,
    "text": "小王子催下乳哥呗",
    "start": 18.24,
    "end": 19.4,
    "duration": 1.16
  },
  {
    "id": 17,
    "text": "好",
    "start": 19.4,
    "end": 19.68,
    "duration": 0.28
  },
  {
    "id": 18,
    "text": "马上好了",
    "start": 21.44,
    "end": 22,
    "duration": 0.56
  },
  {
    "id": 19,
    "text": "我眼看他出去转一圈回来得",
    "start": 22,
    "end": 23.56,
    "duration": 1.56
  },
  {
    "id": 20,
    "text": "脆皮乳哥好了",
    "start": 23.56,
    "end": 24.32,
    "duration": 0.76
  },
  {
    "id": 21,
    "text": "这么快",
    "start": 24.32,
    "end": 24.88,
    "duration": 0.56
  },
  {
    "id": 22,
    "text": "别再包房了",
    "start": 24.88,
    "end": 25.84,
    "duration": 0.96
  },
  {
    "id": 23,
    "text": "我先给你",
    "start": 25.84,
    "end": 26.8,
    "duration": 0.96
  },
  {
    "id": 24,
    "text": "那能行吗",
    "start": 26.8,
    "end": 27.84,
    "duration": 1.04
  },
  {
    "id": 25,
    "text": "不用担心我",
    "start": 27.84,
    "end": 28.48,
    "duration": 0.64
  },
  {
    "id": 26,
    "text": "传菜上桌菜很正常",
    "start": 28.48,
    "end": 29.54,
    "duration": 1.06
  },
  {
    "id": 27,
    "text": "我说我能行吗",
    "start": 29.54,
    "end": 30.8,
    "duration": 1.26
  },
  {
    "id": 28,
    "text": "你别微微操作",
    "start": 30.8,
    "end": 31.62,
    "duration": 0.82
  },
  {
    "id": 29,
    "text": "再刮上我",
    "start": 31.62,
    "end": 32.28,
    "duration": 0.66
  },
  {
    "id": 30,
    "text": "如果全世界都指责你",
    "start": 32.28,
    "end": 33.58,
    "duration": 1.3
  },
  {
    "id": 31,
    "text": "我将把你护在心底",
    "start": 33.58,
    "end": 35.28,
    "duration": 1.7
  },
  {
    "id": 32,
    "text": "哎呀我的妈",
    "start": 35.28,
    "end": 36.06,
    "duration": 0.78
  },
  {
    "id": 33,
    "text": "快给我来瓶安奶剂",
    "start": 36.06,
    "end": 37.22,
    "duration": 1.16
  },
  {
    "id": 34,
    "text": "你不是喜欢张美玲的吗",
    "start": 37.22,
    "end": 38.48,
    "duration": 1.26
  },
  {
    "id": 35,
    "text": "还语言骚扰我干啥呀",
    "start": 38.48,
    "end": 39.9,
    "duration": 1.42
  },
  {
    "id": 36,
    "text": "张美玲不搭理我",
    "start": 39.9,
    "end": 40.84,
    "duration": 0.94
  },
  {
    "id": 37,
    "text": "兜兜转转",
    "start": 40.84,
    "end": 41.48,
    "duration": 0.64
  },
  {
    "id": 38,
    "text": "还是你",
    "start": 41.48,
    "end": 42.24,
    "duration": 0.76
  },
  {
    "id": 39,
    "text": "都爱你都爱你",
    "start": 42.24,
    "end": 44.52,
    "duration": 2.28
  },
  {
    "id": 40,
    "text": "你再不搭理我",
    "start": 44.52,
    "end": 45.32,
    "duration": 0.8
  },
  {
    "id": 41,
    "text": "小满的烧焦皮蛋",
    "start": 45.32,
    "end": 46.46,
    "duration": 1.14
  },
  {
    "id": 42,
    "text": "这么快",
    "start": 46.46,
    "end": 46.96,
    "duration": 0.5
  },
  {
    "id": 43,
    "text": "别再包房了",
    "start": 46.96,
    "end": 47.58,
    "duration": 0.62
  },
  {
    "id": 44,
    "text": "我先给你们",
    "start": 47.58,
    "end": 48.16,
    "duration": 0.58
  },
  {
    "id": 45,
    "text": "你能拿规矩操作",
    "start": 48.16,
    "end": 50.18,
    "duration": 2.02
  },
  {
    "id": 46,
    "text": "动作比感情优势",
    "start": 50.18,
    "end": 51.5,
    "duration": 1.32
  },
  {
    "id": 47,
    "text": "你恋爱脑又长出来了",
    "start": 51.5,
    "end": 52.64,
    "duration": 1.14
  },
  {
    "id": 48,
    "text": "我现在不是恋爱脑了",
    "start": 52.64,
    "end": 53.8,
    "duration": 1.16
  },
  {
    "id": 49,
    "text": "我昨天手术把恋爱脑摘了",
    "start": 53.8,
    "end": 55.34,
    "duration": 1.54
  },
  {
    "id": 50,
    "text": "我现在是无脑爱你",
    "start": 55.34,
    "end": 56.84,
    "duration": 1.5
  },
  {
    "id": 51,
    "text": "我不会和同事谈恋爱的",
    "start": 56.84,
    "end": 58.54,
    "duration": 1.7
  },
  {
    "id": 52,
    "text": "能和我做同事的能有啥本事",
    "start": 58.54,
    "end": 60.58,
    "duration": 2.04
  },
  {
    "id": 53,
    "text": "我正三清",
    "start": 60.58,
    "end": 61.66,
    "duration": 1.08
  },
  {
    "id": 54,
    "text": "你正三清",
    "start": 61.66,
    "end": 62.42,
    "duration": 0.76
  },
  {
    "id": 55,
    "text": "咱俩和西北三相对照大冷天",
    "start": 62.42,
    "end": 64.62,
    "duration": 2.2
  },
  {
    "id": 56,
    "text": "最开始点的排骨炖鸡手还没上呢",
    "start": 64.62,
    "end": 66.64,
    "duration": 2.02
  },
  {
    "id": 57,
    "text": "排骨去他是不是上错了好嘞了送下这内衣物子来传单上头才很正常能挖闺女就上小小凉了肯定凉啊那给不给客人上啊上的话呢",
    "start": 66.64,
    "end": 77.316,
    "duration": 10.676
  },
  {
    "id": 58,
    "text": "太多凉了",
    "start": 77.316,
    "end": 77.756,
    "duration": 0.44
  },
  {
    "id": 59,
    "text": "今天到五星里",
    "start": 77.756,
    "end": 78.256,
    "duration": 0.5
  },
  {
    "id": 60,
    "text": "先问包房来一趟",
    "start": 78.256,
    "end": 78.816,
    "duration": 0.56
  },
  {
    "id": 61,
    "text": "我来我来",
    "start": 78.816,
    "end": 81.516,
    "duration": 2.7
  },
  {
    "id": 62,
    "text": "我来我来",
    "start": 81.516,
    "end": 81.716,
    "duration": 0.2
  },
  {
