  },
  {
    "id": 77,
    "text": "我来我来",
    "start": 83.956,
    "end": 84.096,
    "duration": 0.14
  },
  {
    "id": 78,
    "text": "我来我来",
    "start": 84.096,
    "end": 84.256,
    "duration": 0.16
  },
  {
    "id": 79,
    "text": "不如省掉中间商",
    "start": 84.256,
    "end": 85.316,
    "duration": 1.06
  },
  {
    "id": 80,
    "text": "直接找吴景磊打小花卖了",
    "start": 85.316,
    "end": 86.876,
    "duration": 1.56
  },
  {
    "id": 81,
    "text": "刚才还帮咱俩能给咱俩先上菜",
    "start": 86.876,
    "end": 88.616,
    "duration": 1.74
  },
  {
    "id": 82,
    "text": "终于知道为什么补上办公室恋情了",
    "start": 88.616,
    "end": 90.836,
    "duration": 2.22
  },
  {
    "id": 83,
    "text": "遇到问题很难迎之处理",
    "start": 90.836,
    "end": 92.476,
    "duration": 1.64
  },
  {
    "id": 84,
    "text": "与其逼自己一把",
    "start": 92.476,
    "end": 94.016,
    "duration": 1.54
  },
  {
    "id": 85,
    "text": "不如帮自己一码",
    "start": 94.016,
    "end": 95.096,
    "duration": 1.08
  },
  {
    "id": 86,
    "text": "卖了",
    "start": 95.096,
    "end": 96.136,
    "duration": 1.04
  },
  {
    "id": 87,
    "text": "吴景磊向外包房来一趟",
    "start": 96.136,
    "end": 97.476,
    "duration": 1.34
  },
  {
    "id": 88,
    "text": "手满的地方线",
    "start": 97.476,
    "end": 98.436,
    "duration": 0.96
  },
  {
    "id": 89,
    "text": "人呢",
    "start": 98.436,
    "end": 99.936,
    "duration": 1.5
  },
  {
    "id": 90,
    "text": "不干什么菜直接上来吧",
    "start": 99.936,
    "end": 101.176,
    "duration": 1.24
  },
  {
    "id": 91,
    "text": "我们规定传菜不能直接上菜",
    "start": 101.176,
    "end": 103.036,
    "duration": 1.86
  },
  {
    "id": 92,
    "text": "没事放它凉了上来吧",
    "start": 103.036,
    "end": 104.296,
    "duration": 1.26
  },
  {
    "id": 93,
    "text": "美莲",
    "start": 104.296,
    "end": 104.776,
    "duration": 0.48
  },
  {
    "id": 94,
    "text": "地方线你上的呀",
    "start": 104.776,
    "end": 105.936,
    "duration": 1.16
  },
  {
    "id": 95,
    "text": "没有啊我挪车去了",
    "start": 105.936,
    "end": 106.796,
    "duration": 0.86
  },
  {
    "id": 96,
    "text": "换了",
    "start": 106.796,
    "end": 107.116,
    "duration": 0.32
  },
  {
    "id": 97,
    "text": "奔驰瓜仔二手车卖了卖十七万卖个人了",
    "start": 107.116,
    "end": 109.116,
    "duration": 2.0
  },
  {
    "id": 98,
    "text": "没中间商低价说加价卖",
    "start": 109.116,
    "end": 110.496,
    "duration": 1.38
  },
  {
    "id": 99,
    "text": "我上啥锅呀",
    "start": 115.316,
    "end": 116.316,
    "duration": 1.0
  },
  {
    "id": 100,
    "text": "我上上菜了",
    "start": 116.316,
    "end": 117.316,
    "duration": 1.0
  },
  {
    "id": 101,
    "text": "我没上你没上",
    "start": 117.316,
    "end": 118.316,
    "duration": 1.0
  },
  {
    "id": 102,
    "text": "他自己飞上去的",
    "start": 118.316,
    "end": 119.316,
    "duration": 1.0
  },
  {
    "id": 103,
    "text": "我想过一个人为我哭泣",
    "start": 119.316,
    "end": 121.316,
    "duration": 2.0
  },
  {
    "id": 104,
    "text": "我没想过两个人为我争吵",
    "start": 121.316,
    "end": 122.316,
    "duration": 1.0
  },
  {
    "id": 105,
    "text": "小小刚才我替你上菜了",
    "start": 122.316,
    "end": 124.316,
    "duration": 2.0
  },
  {
    "id": 106,
    "text": "你上你",
    "start": 126.316,
    "end": 127.316,
    "duration": 1.0
  },
  {
    "id": 107,
    "text": "这不菜啊",
    "start": 128.316,
    "end": 130.316,
    "duration": 2.0
  },
  {
    "id": 108,
    "text": "小黄",
    "start": 130.316,
    "end": 131.316,
    "duration": 1.0
  },
  {
    "id": 109,
    "text": "那虾汁包房地方线呢",
    "start": 131.316,
    "end": 132.316,
    "duration": 1.0
  },
  {
    "id": 110,
    "text": "我去",
    "start": 132.316,
    "end": 133.316,
    "duration": 1.0
  },
  {
    "id": 111,
    "text": "咋整啊",
    "start": 133.316,
    "end": 134.316,
    "duration": 1.0
  },
  {
    "id": 112,
    "text": "",
    "start": 134.316,
    "end": 134.316,
    "duration": 0.0
  },
  {
    "id": 113,
    "text": "我爱他",
    "start": 134.316,
    "end": 135.316,
    "duration": 1.0
  },
  {
    "id": 114,
    "text": "职场就是职场",
    "start": 135.316,
    "end": 136.316,
    "duration": 1.0
  },
  {
    "id": 115,
    "text": "规矩就是规矩",
    "start": 136.316,
    "end": 137.316,
    "duration": 1.0
  },
  {
    "id": 116,
    "text": "不要让感情变加质",
    "start": 137.316,
    "end": 138.316,
    "duration": 1.0
  },
  {
    "id": 117,
    "text": "规矩职场",
    "start": 138.316,
    "end": 139.316,
    "duration": 1.0
  },
  {
    "id": 118,
    "text": "这不菜吗",
    "start": 140.316,
    "end": 141.316,
    "duration": 1.0
  }
]